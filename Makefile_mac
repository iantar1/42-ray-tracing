NAME = RT

SRCS = srcs/*.cpp

UNAME := $(shell uname -s)
PLATFORM ?= $(UNAME)

FLAGS = -I/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1
DEBUG = -g
MLX = libmlx.a

ifeq ($(PLATFORM), Darwin)
	PLATFORM_FLAG = -DMACOS
else
	PLATFORM_FLAG = -DLINUX
endif

all: $(NAME)
$(NAME):
		g++ -std=c++17 $(DEBUG) $(FLAGS) $(PLATFORM_FLAG) main.cpp $(SRCS) -o $(NAME) -L. -lmlx
clean:

fclean: clean
		rm -rf $(NAME)
re: fclean all

.PHONY: all clan fclean re